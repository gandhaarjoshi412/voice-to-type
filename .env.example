# ============================================================
#  voice-to-type — environment variables
#  Copy this file to .env and fill in your own values.
#  NEVER commit the actual .env file to version control.
# ============================================================

# Groq API key — get yours at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Global hotkey to trigger voice recording (pynput format)
# Default: ctrl+shift+space
HOTKEY=ctrl+shift+space

# Global hotkey to trigger the Search/History Finder UI
# Default: ctrl+shift+f
SEARCH_HOTKEY=ctrl+shift+f
