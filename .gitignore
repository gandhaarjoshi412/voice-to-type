# ============================================================
#  voice-to-type — .gitignore
# ============================================================

# ------ Secrets & environment --------------------------------
.env
*.env.local
*.env.*.local

# ------ Python virtual environment --------------------------
.venv/
venv/
env/
ENV/

# ------ Python cache & compiled bytecode --------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# ------ Distribution / packaging ----------------------------
dist/
build/
*.egg-info/
*.egg
MANIFEST

# ------ Testing & coverage ----------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# ------ Type checkers ---------------------------------------
.mypy_cache/
.dmypy.json
.pytype/
.pyre/

# ------ IDEs & editors --------------------------------------
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ------ OS generated files ----------------------------------
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ------ Logs & temp files -----------------------------------
*.log
*.tmp
*.temp

# ------ Application Data ------------------------------------
data/
